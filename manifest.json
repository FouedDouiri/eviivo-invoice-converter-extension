{
	"manifest_version": 3,
	"name": "Currency Converter",
	"version": "1.0",
	"description": "Converts prices to Tunisian Dinar (TND) using Open Exchange Rates API.",
	"permissions": ["activeTab", "scripting", "storage"],
	"background": {
		"service_worker": "background.js"
	},
	"action": {},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"]
		}
	]
}
